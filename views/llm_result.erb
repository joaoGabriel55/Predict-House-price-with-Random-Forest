<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Prediction Result</title>
  <link rel="stylesheet" href="/style.css">
  <style>
    .extracted-params {
      margin-top: 20px;
      padding: 20px;
      background: linear-gradient(135deg, #e3f2fd, #bbdefb);
      border-radius: 12px;
      animation: fadeIn 0.4s ease;
    }

    .extracted-params h2 {
      font-size: 1rem;
      color: #1565c0;
      margin-bottom: 12px;
      text-align: center;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .params-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 16px;
    }

    .param-item {
      background: white;
      padding: 12px;
      border-radius: 8px;
      text-align: center;
    }

    .param-label {
      font-size: 0.75rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 4px;
    }

    .param-value {
      font-size: 1.2rem;
      font-weight: 700;
      color: #1565c0;
    }

    .original-text {
      margin-top: 16px;
      padding: 12px;
      background: rgba(255, 255, 255, 0.7);
      border-radius: 8px;
      border-left: 4px solid #1565c0;
    }

    .original-text .label {
      font-size: 0.75rem;
      color: #666;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 6px;
    }

    .original-text .text {
      font-size: 0.9rem;
      color: #333;
      font-style: italic;
      line-height: 1.4;
    }
  </style>
</head>
<body>
  <div class="card">
    <h1>🏠 Price Prediction</h1>
    <p class="subtitle">AI-Powered Analysis Complete</p>

    <div class="extracted-params">
      <h2>Extracted Parameters</h2>
      <div class="params-grid">
        <div class="param-item">
          <div class="param-label">Area</div>
          <div class="param-value"><%= area %> sq meters</div>
        </div>
        <div class="param-item">
          <div class="param-label">Rooms</div>
          <div class="param-value"><%= rooms %></div>
        </div>
        <div class="param-item">
          <div class="param-label">Bathrooms</div>
          <div class="param-value"><%= bathrooms %></div>
        </div>
        <div class="param-item">
          <div class="param-label">Age</div>
          <div class="param-value"><%= age %> years</div>
        </div>
      </div>

      <div class="original-text">
        <div class="label">Your Description</div>
        <div class="text">"<%= original_text %>"</div>
      </div>
    </div>

    <div class="result">
      <div class="label">Predicted Price</div>
      <div class="price">$<%= format('%.2f', price) %>K</div>
    </div>

    <a href="/llm" class="back-link">← Try Another Prediction</a>
  </div>
</body>
</html>
